<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:clickable="true">

    <!-- Centered container (FrameLayout so we can position the close icon at top-right) -->
    <FrameLayout
        android:id="@+id/overlay_container"
        android:layout_width="wrap_content"
        android:layout_height="418dp"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="@drawable/overlay_bg"
        android:clickable="true"
        android:elevation="12dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:padding="16dp">

        <!-- Close / cross icon in the top-right of the card -->
        <ImageButton
            android:id="@+id/overlay_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|top"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_close"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />


        <!-- Main content inside the card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/overlay_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/overlay_title"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Rating rows -->
            <LinearLayout
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_voice_quality"
                        android:textAlignment="center"
                        android:textColor="#000000"
                        android:textSize="23sp" />

                </LinearLayout>

                <RatingBar
                    android:id="@+id/rating_voice_quality"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:contentDescription="@string/label_voice_quality"
                    android:focusable="true"
                    android:isIndicator="false"
                    android:numStars="5"
                    android:rating="5"
                    android:stepSize="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_delays"
                        android:textColor="#000000"
                        android:textSize="14sp" />

                </LinearLayout>

                <RatingBar
                    android:id="@+id/rating_delays"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:contentDescription="@string/label_delays"
                    android:focusable="true"
                    android:isIndicator="false"
                    android:numStars="5"
                    android:rating="5"
                    android:stepSize="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_network_reliability"
                        android:textColor="#000000"
                        android:textSize="14sp" />

                </LinearLayout>

                <RatingBar
                    android:id="@+id/rating_network_reliability"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:contentDescription="@string/label_network_reliability"
                    android:focusable="true"
                    android:isIndicator="false"
                    android:numStars="5"
                    android:rating="5"
                    android:stepSize="1" />

            </LinearLayout>

            <!-- Comment -->
            <EditText
                android:id="@+id/overlay_comment"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints="comment"
                android:hint="@string/hint_comment"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/overlay_submit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/btn_submit" />
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
