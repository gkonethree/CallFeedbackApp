<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:clickable="true">

    <!-- Centered main container -->
    <LinearLayout
        android:id="@+id/overlay_container"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="@drawable/overlay_bg"
        android:clickable="true"
        android:elevation="12dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header with Title and Close Button in same row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/overlay_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/overlay_title"
                android:textColor="#000000"
                android:textSize="23sp"
                android:textStyle="bold" />

            <!-- Close button in top-right -->
            <ImageButton
                android:id="@+id/overlay_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_close"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />
        </LinearLayout>

        <!-- Main scrollable content (Voice Quality, Audio Issues, Environment) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <!-- Voice Quality Rating -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Voice Quality"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Discrete Star Rating -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Star 1 -->
                        <ImageButton
                            android:id="@+id/star_1"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="6dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Star 1"
                            android:padding="6dp"
                            android:src="@drawable/ic_star_empty"
                            android:scaleType="centerInside"
                            android:tag="1" />

                        <!-- Star 2 -->
                        <ImageButton
                            android:id="@+id/star_2"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="6dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Star 2"
                            android:padding="6dp"
                            android:src="@drawable/ic_star_empty"
                            android:scaleType="centerInside"
                            android:tag="2" />

                        <!-- Star 3 -->
                        <ImageButton
                            android:id="@+id/star_3"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="6dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Star 3"
                            android:padding="6dp"
                            android:src="@drawable/ic_star_empty"
                            android:scaleType="centerInside"
                            android:tag="3" />

                        <!-- Star 4 -->
                        <ImageButton
                            android:id="@+id/star_4"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="6dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Star 4"
                            android:padding="6dp"
                            android:src="@drawable/ic_star_empty"
                            android:scaleType="centerInside"
                            android:tag="4" />

                        <!-- Star 5 -->
                        <ImageButton
                            android:id="@+id/star_5"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Star 5"
                            android:padding="6dp"
                            android:src="@drawable/ic_star_empty"
                            android:scaleType="centerInside"
                            android:tag="5" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Specific Audio Issues -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Audio Issues (Select all that apply)"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Tags container in rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start"
                        android:orientation="vertical">

                        <!-- Row 1: Call was dropped, Could not hear other -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <ToggleButton
                                android:id="@+id/audio_issue_dropped"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/tag_selector"
                                android:gravity="center"
                                android:padding="0dp"
                                android:textColor="#000000"
                                android:textOff="Call dropped"
                                android:textOn="Call dropped"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <ToggleButton
                                android:id="@+id/audio_issue_hear_other"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/tag_selector"
                                android:gravity="center"
                                android:padding="0dp"
                                android:textColor="#000000"
                                android:textOff="Can't hear them"
                                android:textOn="Can't hear them"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Row 2: Other could not hear me, Background noise -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <ToggleButton
                                android:id="@+id/audio_issue_hear_me"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/tag_selector"
                                android:gravity="center"
                                android:padding="0dp"
                                android:textColor="#000000"
                                android:textOff="They can't hear"
                                android:textOn="They can't hear"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <ToggleButton
                                android:id="@+id/audio_issue_background_noise"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:background="@drawable/tag_selector"
                                android:gravity="center"
                                android:padding="0dp"
                                android:textColor="#000000"
                                android:textOff="Background noise"
                                android:textOn="Background noise"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Row 3: Echo -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ToggleButton
                                android:id="@+id/audio_issue_echo"
                                android:layout_width="120dp"
                                android:layout_height="40dp"
                                android:background="@drawable/tag_selector"
                                android:gravity="center"
                                android:padding="0dp"
                                android:textColor="#000000"
                                android:textOff="Echo"
                                android:textOn="Echo"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Environment -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Environment"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Row 1: Indoor and Outdoor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- Indoor -->
                        <CheckBox
                            android:id="@+id/env_indoor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Indoor" />

                        <!-- Outdoor -->
                        <CheckBox
                            android:id="@+id/env_outdoor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Outdoor" />
                    </LinearLayout>

                    <!-- Row 2: In Vehicle and Noisy Area -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <!-- In Vehicle -->
                        <CheckBox
                            android:id="@+id/env_vehicle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="In Vehicle" />

                        <!-- Noisy Area -->
                        <CheckBox
                            android:id="@+id/env_noisy_area"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Noisy Area" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- Comments section - separate scrollable container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <!-- Comments label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Comments"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Comments EditText with outline border -->
            <EditText
                android:id="@+id/overlay_comment"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:autofillHints="comment"
                android:background="@drawable/comment_box_outline"
                android:gravity="top|start"
                android:hint="@string/hint_comment"
                android:inputType="textCapSentences|textMultiLine"
                android:padding="8dp"
                android:scrollbars="vertical"
                android:overScrollMode="always" />
        </LinearLayout>

        <!-- Submit Button - positioned at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlay_submit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_submit" />
        </LinearLayout>

    </LinearLayout>


</FrameLayout>
