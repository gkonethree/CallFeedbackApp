<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked state (selected tag) - Blue background with white text -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#069c2e"/>
                    <corners android:radius="20dp" />
                    <stroke android:width="2dp" android:color="#0D47A1" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Unchecked state (unselected tag) - Light gray background with dark text -->
    <item android:state_checked="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#27e85b"  />
                    <corners android:radius="20dp" />
                    <stroke android:width="1.5dp" android:color="#CCCCCC" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
